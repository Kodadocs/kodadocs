---
const freeFeatures = [
  "Unlimited doc generation",
  "All MCP tools",
  "Framework detection",
  "Screenshot capture",
  "VitePress output",
  "Self-host anywhere",
  "1 default theme",
  '"Powered by KodaDocs" badge',
];

const proFeatures = [
  "Everything in Free",
  "yourapp.kodadocs.com hosting",
  "3-5 premium themes",
  "Badge removable",
  "Custom CSS",
  "Search analytics",
  "Password protection",
  "Versioned docs",
];
---

<section id="pricing" class="py-24 px-4 sm:px-6 lg:px-8 bg-bg-secondary">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">Simple pricing</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">Free forever for self-hosted. Upgrade for managed hosting and premium features.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Free tier -->
      <div class="rounded-xl border border-border bg-bg-primary p-8">
        <h3 class="text-lg font-semibold text-text-primary mb-1">Free</h3>
        <p class="text-text-muted text-sm mb-6">For getting started</p>
        <div class="mb-8">
          <span class="text-4xl font-bold text-text-primary">$0</span>
          <span class="text-text-muted text-sm">/forever</span>
        </div>
        <a href="https://github.com/kodadocs/kodadocs" class="block w-full text-center py-2.5 px-4 rounded-lg border border-border text-text-primary text-sm font-medium hover:bg-surface transition-colors mb-8">
          Get Started
        </a>
        <ul class="space-y-3">
          {freeFeatures.map((feature) => (
            <li class="flex items-center gap-3 text-sm text-text-secondary">
              <svg class="w-4 h-4 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>

      <!-- Pro tier -->
      <div class="rounded-xl border border-accent/30 bg-bg-primary p-8 ring-1 ring-accent/10 relative">
        <div class="absolute -top-3 left-8 px-3 py-0.5 bg-accent text-white text-xs font-medium rounded-full">
          Popular
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-1">Pro</h3>
        <p class="text-text-muted text-sm mb-6">For shipping fast</p>
        <div class="mb-8">
          <span class="text-4xl font-bold text-text-primary">$12</span>
          <span class="text-text-muted text-sm">/month</span>
        </div>
        <a href="#" class="block w-full text-center py-2.5 px-4 rounded-lg bg-accent hover:bg-accent-hover text-white text-sm font-medium transition-colors mb-8">
          Start Free Trial
        </a>
        <ul class="space-y-3">
          {proFeatures.map((feature) => (
            <li class="flex items-center gap-3 text-sm text-text-secondary">
              <svg class="w-4 h-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="text-center text-text-muted text-xs mt-8">
      You bring your own Anthropic API key. Generation is never gated — free or Pro.
    </p>
  </div>
</section>
