---
const productLinks = [
  { label: "Features", href: "#features" },
  { label: "Pricing", href: "#pricing" },
  { label: "Showcase", href: "/showcase" },
  { label: "Changelog", href: "/changelog" },
];

const resourceLinks = [
  { label: "Documentation", href: "/docs" },
  { label: "Blog", href: "/blog" },
  { label: "GitHub", href: "https://github.com/kodadocs/kodadocs" },
  { label: "PyPI", href: "https://pypi.org/project/kodadocs/" },
];

const companyLinks = [
  { label: "About", href: "/about" },
  { label: "Privacy", href: "/privacy" },
  { label: "Terms", href: "/terms" },
];
---

<footer class="border-t border-border py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg width="24" height="24" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="6" fill="#6958E2"/>
            <text x="16" y="23" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="18" fill="white">K</text>
          </svg>
          <span class="text-text-primary font-semibold">KodaDocs</span>
        </a>
        <p class="text-text-muted text-sm leading-relaxed">
          AI-generated help docs for your web app — in minutes, not weeks.
        </p>
      </div>

      <div>
        <h4 class="text-text-primary text-sm font-semibold mb-4">Product</h4>
        <ul class="space-y-2">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-text-secondary transition-colors text-sm">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-text-primary text-sm font-semibold mb-4">Resources</h4>
        <ul class="space-y-2">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-text-secondary transition-colors text-sm" target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-text-primary text-sm font-semibold mb-4">Company</h4>
        <ul class="space-y-2">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-text-secondary transition-colors text-sm">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 border-t border-border">
      <p class="text-text-muted text-xs">&copy; 2026 KodaDocs. All rights reserved.</p>
      <div class="flex items-center gap-4 mt-4 sm:mt-0">
        <a href="https://github.com/kodadocs/kodadocs" class="text-text-muted hover:text-text-secondary transition-colors" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://x.com/kodadocs" class="text-text-muted hover:text-text-secondary transition-colors" target="_blank" rel="noopener noreferrer" aria-label="X/Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
