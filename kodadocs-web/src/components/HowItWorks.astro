---
const steps = [
  {
    number: "01",
    title: "Install",
    description: "Add KodaDocs to your project and configure the MCP server in Claude Code.",
    code: "pip install kodadocs",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>`,
  },
  {
    number: "02",
    title: "Tell Claude",
    description: 'Say "Generate docs for my app" and Claude reads your code, captures screenshots, and writes articles.',
    code: '"Generate docs for my app"',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
  },
  {
    number: "03",
    title: "Get Docs",
    description: "A complete help center with annotated screenshots, ready to self-host or deploy to kodadocs.com.",
    code: "yourapp.kodadocs.com",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
];
---

<section id="how-it-works" class="py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">How it works</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">Three steps from zero to a published help center.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-12 left-[16.67%] right-[16.67%] h-px bg-border"></div>

      {steps.map((step) => (
        <div class="relative text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-accent/10 border border-accent/30 text-accent font-bold text-sm mb-6 relative z-10 bg-bg-primary">
            {step.number}
          </div>
          <div class="flex justify-center text-text-secondary mb-4" set:html={step.icon} />
          <h3 class="text-xl font-semibold text-text-primary mb-3">{step.title}</h3>
          <p class="text-text-secondary text-sm mb-4 max-w-xs mx-auto">{step.description}</p>
          <code class="inline-block text-xs bg-surface border border-border rounded-md px-3 py-1.5 text-accent font-mono">
            {step.code}
          </code>
        </div>
      ))}
    </div>
  </div>
</section>
