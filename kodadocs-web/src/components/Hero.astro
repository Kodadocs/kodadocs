<section class="relative pt-32 pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/20 rounded-full blur-[128px] pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-border bg-surface text-xs text-text-secondary mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400"></span>
      Open Source — Free Forever
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary leading-tight mb-6">
      AI-generated help docs for your web app —
      <span class="text-accent">in minutes, not weeks</span>
    </h1>

    <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10">
      Install from PyPI, tell Claude to generate docs, and get a complete help center with annotated screenshots. Free forever for self-hosted. $12/mo to host on kodadocs.com.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <div class="group relative flex items-center gap-3 bg-surface border border-border rounded-lg px-5 py-3 cursor-pointer" id="install-cmd">
        <code class="text-sm text-text-primary font-mono">pip install kodadocs</code>
        <button class="text-text-muted hover:text-text-primary transition-colors" aria-label="Copy install command">
          <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/>
          </svg>
          <svg class="w-4 h-4 check-icon hidden text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </button>
      </div>

      <a href="#how-it-works" class="text-accent hover:text-accent-hover transition-colors text-sm font-medium">
        See how it works ↓
      </a>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <div class="rounded-xl border border-border bg-surface overflow-hidden shadow-2xl shadow-accent/10">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
          <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
          <span class="ml-4 text-xs text-text-muted">yourapp.kodadocs.com</span>
        </div>
        <div class="p-8 sm:p-12 text-center">
          <div class="text-text-muted text-sm mb-4">Product screenshot placeholder</div>
          <div class="h-64 sm:h-96 bg-bg-primary/50 rounded-lg border border-border flex items-center justify-center">
            <span class="text-text-muted text-lg">Generated Help Center Preview</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const cmd = document.getElementById("install-cmd");
  if (cmd) {
    cmd.addEventListener("click", async () => {
      await navigator.clipboard.writeText("pip install kodadocs");
      const copyIcon = cmd.querySelector(".copy-icon");
      const checkIcon = cmd.querySelector(".check-icon");
      if (copyIcon && checkIcon) {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      }
    });
  }
</script>
