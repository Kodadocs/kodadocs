# KodaDocs Environment Variables
#
# RECOMMENDED: Add keys to your MCP server config (scoped to KodaDocs only):
#
#   "kodadocs": {
#     "command": "uvx",
#     "args": ["kodadocs", "mcp"],
#     "env": {
#       "KODADOCS_LICENSE_KEY": "kd_pro_xxxxxxxxxxxx",
#       "CLOUDFLARE_API_TOKEN": "your_token_here"
#     }
#   }
#
# ALTERNATIVE: Set in your shell profile (~/.zshrc or ~/.bashrc).
# CLI users can also pass --license-key per-command.
#
# NOTE: ANTHROPIC_API_KEY is already set by Claude Code — no action needed.

# ── Deploy Provider Tokens (optional) ────────────────────────────────────

# Cloudflare Pages
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Vercel
# VERCEL_TOKEN=your_vercel_token_here

# Netlify
# NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here
# NETLIFY_SITE_ID=your_netlify_site_id_here

# GitHub Pages — no token needed (uses git auth)

# ── KodaDocs Pro ──────────────────────────────────────────────────────────
# For deploying to yourapp.kodadocs.com (Pro feature, $5/mo)
# Get your license key at https://kodadocs.com/pricing
# KODADOCS_LICENSE_KEY=kd_pro_xxxxxxxxxxxx
