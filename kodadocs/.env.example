# KodaDocs Environment Variables
#
# Set these in your shell profile (~/.zshrc or ~/.bashrc).
# If you use Claude Code, ANTHROPIC_API_KEY is already set.

# Required for AI Discovery & Documentation Generation
# export ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Specify the Anthropic model to use (default: claude-sonnet-4-6)
# export ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Deploy Provider Tokens (optional) ────────────────────────────────────
# Set the token for your chosen deploy provider.

# Cloudflare Pages
# export CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Vercel
# export VERCEL_TOKEN=your_vercel_token_here

# Netlify
# export NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here
# export NETLIFY_SITE_ID=your_netlify_site_id_here

# GitHub Pages — no token needed (uses git auth)

# ── KodaDocs Pro ──────────────────────────────────────────────────────────
# For deploying to yourapp.kodadocs.com (Pro feature, $12/mo)
# Get your license key at https://kodadocs.com/pricing
# export KODADOCS_LICENSE_KEY=kd_pro_xxxxxxxxxxxx
