# KodaDocs Environment Variables
# Copy this file to ~/.kodadocs.env
#   cp .env.example ~/.kodadocs.env
# This keeps your keys global (not per-project) so they don't pollute your repos.

# Required for AI Discovery & Documentation Generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Specify the Anthropic model to use (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Deploy Provider Tokens (optional) ────────────────────────────────────
# Uncomment and set the tokens for your chosen deploy provider.

# Cloudflare Pages
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Vercel
# VERCEL_TOKEN=your_vercel_token_here

# Netlify
# NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here
# NETLIFY_SITE_ID=your_netlify_site_id_here

# GitHub Pages — no token needed (uses git auth)

# ── KodaDocs Pro ──────────────────────────────────────────────────────────
# For deploying to yourapp.kodadocs.com (Pro feature, $12/mo)
# Get your license key at https://kodadocs.com/pricing
# KODADOCS_LICENSE_KEY=kd_pro_xxxxxxxxxxxx
